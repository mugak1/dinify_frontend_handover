    "@angular/platform-browser-dynamic": "^17.3.6",
    "@angular/router": "^17.3.6",
    "@ryware/ngx-drag-and-drop-lists": "^2.0.3",
    "angularx-qrcode": "^15.0.0",
    "apexcharts": "^3.48.0",
